PORT=3000
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/database-name
SESSION_SECRET=replace-with-a-long-random-session-secret
OPENWEATHER_API_KEY=replace-with-openweather-api-key
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/admin/auth/google/callback

# NOTE: Register both callback URLs in Google OAuth Console as authorized redirect URIs:
# - http://localhost:3000/admin/auth/google/callback (for admin login)
# - http://localhost:3000/auth/google/callback (for user/guest login)
# In production, use your deployed domain instead of localhost

# Frontend SPA URL used for redirects (change if your frontend runs elsewhere)
FRONTEND_URL=http://localhost:5173
