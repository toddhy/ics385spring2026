<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Properties - Hawaii Tourism</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .header {
            background: white;
            border-radius: 10px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        h1 {
            color: #333;
            margin-bottom: 10px;
        }
        
        .stats {
            color: #666;
            font-size: 1.1rem;
        }
        
        .nav-links {
            margin-top: 15px;
            display: flex;
            gap: 10px;
        }
        
        .nav-links a {
            padding: 8px 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-size: 0.9rem;
            transition: opacity 0.3s;
        }
        
        .nav-links a:hover {
            opacity: 0.9;
        }
        
        .properties-table {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        thead {
            background: #f5f5f5;
            border-bottom: 2px solid #ddd;
        }
        
        th {
            padding: 15px 20px;
            text-align: left;
            font-weight: 600;
            color: #333;
        }
        
        td {
            padding: 15px 20px;
            border-bottom: 1px solid #eee;
            color: #666;
        }
        
        tbody tr:hover {
            background-color: #f9f9f9;
        }
        
        .property-name {
            font-weight: 600;
            color: #333;
        }
        
        .island {
            color: #667eea;
            font-weight: 500;
        }
        
        .amenities-list {
            max-width: 300px;
            font-size: 0.9rem;
        }
        
        .action-btn {
            padding: 8px 12px;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-size: 0.85rem;
            transition: opacity 0.3s;
            display: inline-block;
        }
        
        .action-btn:hover {
            opacity: 0.8;
        }
        
        .no-properties {
            background: white;
            border-radius: 10px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            color: #666;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🌺 All Hawaii Tourism Properties</h1>
            <p class="stats">Total Properties: <strong><%= properties.length %></strong></p>
            
            <div class="nav-links">
                <a href="/">← Back to Home</a>
                <a href="/api/properties">JSON API</a>
            </div>
        </div>
        
        <% if (properties && properties.length > 0) { %>
            <div class="properties-table">
                <table>
                    <thead>
                        <tr>
                            <th>Property Name</th>
                            <th>Island</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Target Segment</th>
                            <th>Reviews</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% properties.forEach(property => { %>
                            <tr>
                                <td class="property-name"><%= property.name %></td>
                                <td class="island"><%= property.island %></td>
                                <td><%= property.type || 'N/A' %></td>
                                <td><%= property.description.substring(0, 50) %>...</td>
                                <td><%= property.targetSegment %></td>
                                <td>
                                    <% if (property.reviews && property.reviews.length > 0) { %>
                                        <%= property.reviews.length %> review<%= property.reviews.length !== 1 ? 's' : '' %>
                                    <% } else { %>
                                        <em>No reviews</em>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/properties/<%= property._id %>" class="action-btn">View Details</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="no-properties">
                <p>No properties found.</p>
            </div>
        <% } %>
    </div>
</body>
</html>
